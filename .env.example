# Frontend env (copy to .env in project root)
# Leave empty in dev — Vite proxies /api and /uploads to localhost:5001
VITE_API_URL=
VITE_ADMIN_URL=http://localhost:5173
# Set to true to show Rath Tracker nav link outside festival dates (local testing)
VITE_RATH_SEASON=true

# Do NOT put server secrets in VITE_* variables — they are embedded in the client bundle.
