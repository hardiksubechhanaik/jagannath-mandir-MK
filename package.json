{
  "name": "sjmmk-website-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --watch server/index.js",
    "dev:all": "concurrently -n site,backend,admin -c blue,green,magenta \"npm run dev\" \"npm run dev:backend\" \"npm run dev:admin\"",
    "dev:admin": "npm run dev --prefix admin-app",
    "dev:backend": "npm run dev --prefix backend",
    "start:server": "node server/index.js",
    "build": "vite build",
    "build:admin": "npm run build --prefix admin-app",
    "build:all": "npm run build && npm run build:admin",
    "start:backend": "npm start --prefix backend",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "leaflet": "^1.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "vite": "^8.1.0"
  }
}
