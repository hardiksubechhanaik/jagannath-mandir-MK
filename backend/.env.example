PORT=5001
MONGO_URI=mongodb://127.0.0.1:27017/mandir_admin
# true = temporary in-memory DB (data lost on every backend restart). false = real MongoDB (persistent).
USE_MEMORY_DB=false
JWT_SECRET=change_me_use_a_long_random_string_in_production
JWT_EXPIRES=7d
CLIENT_URL=http://localhost:5173,http://localhost:5174,https://www.shreejagannathmandirmk.in,https://shreejagannathmandirmk.in

# Rath Yatra live GPS tracker (volunteer admin → public map)
RATH_TRACKER_SECRET=yourpassword

# Rath Yatra memory wall — volunteer approves uploads after OTP
WALL_VOLUNTEER_SECRET=yourpassword
# Set true to return OTP in API response (dev only)
WALL_OTP_DEV=false

# Optional: set before first seed in production (otherwise a random password is generated)
# ADMIN_INITIAL_PASSWORD=

# YouTube channel stats (public page scrape works without a key; API key is optional)
YOUTUBE_CHANNEL_ID=UC5v5xXR21TOo1FywRdDC0rQ
YOUTUBE_API_KEY=
