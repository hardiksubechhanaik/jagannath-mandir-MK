{
  "name": "mandir-admin-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "dev:memory": "USE_MEMORY_DB=true nodemon server.js",
    "start": "node server.js",
    "db:up": "docker compose up -d mongodb",
    "db:down": "docker compose down",
    "seed": "USE_MEMORY_DB=true node seed/seed.js",
    "seed:mongo": "node seed/seed.js",
    "seed:reset": "USE_MEMORY_DB=true node seed/seed.js",
    "seed:reset:mongo": "node seed/seed.js",
    "reset-admin-password": "node scripts/reset-admin-password.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb-memory-server": "^10.4.3",
    "mongoose": "^8.7.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
